// nextflow.config

process {
    executor = 'slurm'
    queue = 'gpu'
    clusterOptions = '--account=your_account'
    
    withName: makePredictions {
        cpus = 4
        memory = '32 GB'
        time = '12h'
        queue = 'gpu'
        
        // Apptainer/container settings
        container = 'path/to/your/graphormercontainer.sif'
        
        // These are environment variables passed to SLURM
        clusterOptions = '''
            --account=your_account
            --cpus-per-task=4
            --mem=32G
            --time=12:00:00
            --partition=gpu
            --gres=gpu:1
        '''
    }
}